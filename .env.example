# ── Server-only (Coolify: add in Environment Variables — never use NEXT_PUBLIC_) ──
EASEBUZZ_KEY=
EASEBUZZ_SALT=
EASEBUZZ_URL=https://pay.easebuzz.in
EASEBUZZ_STATUS_URL=https://dashboard.easebuzz.in/transaction/v2.1/retrieve

# Your live domain — used for Easebuzz payment return URLs (server reads at runtime)
SITE_URL=https://your-domain.com

# Optional: allows server to update order payment status reliably
SUPABASE_SERVICE_ROLE_KEY=

# ── DollerpayX bridge (separate Coolify service — root: /bridge, Dockerfile: bridge/Dockerfile) ──
# BOSSPAY_BRIDGE_SECRET=          (same as DollerpayX admin bridge_secret)
# BOSSPAY_API_BASE=https://api.bosspay24.com
# EASEBUZZ_KEY / EASEBUZZ_SALT    (same values as above)
# STOREFRONT_URL or SITE_URL      (this Next.js app URL)
# BRIDGE_BASE_URL                 (optional — Coolify sets COOLIFY_URL on the bridge service)

# ── Public (safe in browser — Coolify: add before or during build) ──
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
