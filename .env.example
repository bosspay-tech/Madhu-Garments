# ── Server-only (Coolify: add in Environment Variables — never use NEXT_PUBLIC_) ──
EASEBUZZ_KEY=
EASEBUZZ_SALT=
EASEBUZZ_URL=https://pay.easebuzz.in
EASEBUZZ_STATUS_URL=https://dashboard.easebuzz.in/transaction/v2.1/retrieve

# Your live domain — used for Easebuzz payment return URLs (server reads at runtime)
SITE_URL=https://your-domain.com

# Optional: allows server to update order payment status reliably
SUPABASE_SERVICE_ROLE_KEY=

# Admin access (protects /admin page)
# Comma-separated list of admin emails (case-insensitive)
ADMIN_EMAILS=

# Promo code (checkout only)
PROMO_CODE=
PROMO_DISCOUNT_RUPEES=

# ── DollerpayX bridge (runs INSIDE this Next.js app at /bosspay/v1/* — NO separate service) ──
# DollerpayX calls https://<this-domain>/bosspay/v1/{collect,status,health}.
BOSSPAY_BRIDGE_SECRET=                                   # same value as the lender PG bridge_secret in DPX admin
BOSSPAY_API_BASE=https://dpxreal.com/backend-api         # DPX callback base (live host)
# Persistent txn store (recommended; falls back to in-memory if unset):
SUPABASE_URL=                                            # same as NEXT_PUBLIC_SUPABASE_URL

# ── Public (safe in browser — Coolify: add before or during build) ──
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
