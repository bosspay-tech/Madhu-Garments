{
  "name": "madhu-garments-bosspay-bridge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "BossPay bridge for Madhu Garments — DollerpayX Easebuzz collect/status",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bosspay/bridge-node": "file:./vendor/bosspay-bridge-node-1.0.0.tgz",
    "@dollerpayx-easebuzz/bridge-node": "file:vendor/dollerpayx-easebuzz-bridge.zip",
    "dotenv": "^17.4.2",
    "express": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.6.0"
  }
}
