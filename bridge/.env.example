# --- DollerpayX shared bridge contract ---
# The same secret you paste into DollerpayX admin → PGs → (this PG) → bridge_secret.
BOSSPAY_BRIDGE_SECRET=change-me-to-a-long-random-string
# DollerpayX API base the bridge POSTs webhooks back to.
BOSSPAY_API_BASE=https://api.bosspay24.com

# --- Easebuzz merchant credentials (stay on THIS host, never on DollerpayX) ---
EASEBUZZ_KEY=your-easebuzz-merchant-key
EASEBUZZ_SALT=your-easebuzz-merchant-salt
# prod (live) or test (sandbox). Defaults to prod.
EASEBUZZ_ENV=prod

# Port to listen on (optional).
PORT=3000
