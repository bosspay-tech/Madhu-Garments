# Coolify: add these in Environment Variables (no .env file needed in production).
# Coolify auto-injects COOLIFY_URL / COOLIFY_FQDN — BRIDGE_BASE_URL is optional if those are set.

BOSSPAY_BRIDGE_SECRET=
BOSSPAY_API_BASE=https://api.bosspay24.com

# Optional if Coolify sets COOLIFY_URL or COOLIFY_FQDN on this service
BRIDGE_BASE_URL=https://your-bridge-domain.com

# Your Next.js storefront domain (or use SITE_URL — same value works)
STOREFRONT_URL=https://your-storefront-domain.com

EASEBUZZ_KEY=
EASEBUZZ_SALT=
EASEBUZZ_URL=https://pay.easebuzz.in
EASEBUZZ_STATUS_URL=https://dashboard.easebuzz.in/transaction/v2.1/retrieve

PORT=3000
